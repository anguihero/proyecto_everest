# Everest Experience - Git Ignore

# Dependencias y módulos
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Variables de entorno y secretos
.env
.env.local
.env.production
.env.development
.env.test
*.key
*.pem
secrets/
credentials/

# Configuración de Supabase local
supabase/.temp/
supabase/.branches/
.supabase/

# Archivos de IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# Build y distribución
dist/
build/
.cache/
*.js.map
*.css.map

# Testing
coverage/
.nyc_output/
*.lcov
test-results/

# Temporales
tmp/
temp/
*.tmp

# Assets pesados (comprimir antes de commitear)
*.psd
*.ai
*.sketch
!docs/image*.png

# Backups de base de datos
*.sql.backup
*.dump

# Sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Python (si se usan scripts de análisis)
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
ENV/

# Documentación generada automáticamente
docs/api-docs/generated/

# Certificados SSL locales
*.crt
*.cer
*.p12
